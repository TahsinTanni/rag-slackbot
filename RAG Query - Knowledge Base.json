{
  "name": "RAG Query - Knowledge Base",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Extract and validate the query from the webhook body\nconst body = $input.first().json.body;\nconst query = body?.query || body?.text || '';\n\nif (!query || query.trim() === '') {\n throw new Error('No query provided in request body. Send { \"query\": \"your question here\" }');\n}\n\nreturn [{ json: { query: query.trim() } }];"
      },
      "id": "b4c18153-cc97-4c7e-8762-09bc580a2df8",
      "name": "Extract Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -512,
        544
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/embeddings",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"nomic-embed-text\", prompt: $json.query }) }}",
        "options": {}
      },
      "id": "cef7f827-257a-4fd3-a910-51f15e01d4d5",
      "name": "Ollama - Embed Query",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -288,
        544
      ]
    },
    {
      "parameters": {
        "jsCode": "// Merge embedding back with original query\nconst query = $('Extract Query').first().json.query;\nconst embedding = $input.first().json.embedding;\n\nreturn [{ json: { query, embedding } }];"
      },
      "id": "96202de8-2c5b-4f91-9c5e-0d92d4e75924",
      "name": "Merge Query + Embedding",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        544
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select * from match_documents($1::vector, $2, $3);",
        "options": {
          "queryReplacement": "={{ [`[${$json.embedding.join(',')}]`, 0.0, 10] }}"
        }
      },
      "id": "25ba396a-fd40-406f-b083-bffd755559dd",
      "name": "Supabase - match_documents",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        160,
        544
      ],
      "credentials": {
        "postgres": {
          "id": "A9yJq4r8Yb4kYctm",
          "name": "Postgres account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Assemble context block and compute confidence score\nconst chunks = $input.all();\nconst query = $('Extract Query').first().json.query;\n\nconst topScore = chunks.length > 0 ? parseFloat(chunks[0].json.similarity) : 0;\n\nconst context = chunks\n .map((c, i) => `[Source ${i+1}: ${c.json.source_file} | dept: ${c.json.department}]\\n${c.json.content}`)\n .join('\\n\\n');\n\nconst sources = chunks.map(c => c.json.source_file);\nconst uniqueSources = [...new Set(sources)];\n\nreturn [{\n json: {\n query,\n context,\n sources: uniqueSources,\n top_similarity: topScore,\n chunk_count: chunks.length\n }\n}];"
      },
      "id": "bc70cc05-f693-4bf4-a28b-266a3095d792",
      "name": "Build Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
        544
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "confidence-check",
              "leftValue": "={{ $json.top_similarity }}",
              "rightValue": 0.5,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "4bec386d-c687-4434-a1cb-87a7e63a16c4",
      "name": "Confidence Check (≥0.5)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        608,
        544
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [ { parts: [ { text: `Answer the question using ONLY the context below. If the answer is clearly present in the context, answer it directly and do not refuse. If the answer is not in the context, say exactly: \"I don't have enough information to answer this.\"\\n\\nContext:\\n${$json.context}\\n\\nQuestion: ${$json.query}\\n\\nAnswer:` } ] } ] }) }}",
        "options": {}
      },
      "id": "6391ca84-1a5e-470b-9547-69531d0b4273",
      "name": "Gemini - Generate Answer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        832,
        448
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "9cFVmWgT3ieBQVlT",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Format the grounded answer with sources\nconst response = $input.first().json;\nconst answer = response.candidates[0].content.parts[0].text.trim();\nconst ctx = $('Build Context').first().json;\n\nconst sourcesArray = ctx.sources;\n\nreturn [{\n json: {\n query: ctx.query,\n answer,\n sources: sourcesArray,\n confidence: ctx.top_similarity,\n escalated: false,\n final_message: `${answer}\\n\\n_Sources: ${sourcesArray.join(', ')}_`,\n response_type: 'answer'\n }\n}];"
      },
      "id": "de3c15c1-f488-4e76-875a-4881bcd8ebd8",
      "name": "Format Answer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1056,
        448
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "insert into usage_log (query, answer, sources, confidence, escalated) values ($1, $2, $3::text[], $4, $5);",
        "options": {
          "queryReplacement": "={{ [$json.query, $json.answer, $json.sources, $json.confidence, $json.escalated] }}"
        }
      },
      "id": "62d9afbb-1e2a-4b03-bbf1-cfa4b096d518",
      "name": "Log Answer",
