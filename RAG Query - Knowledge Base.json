    {
      "parameters": {
        "jsCode": "// Low confidence — prepare escalation\nconst ctx = $('Build Context').first().json;\n\nreturn [{\n json: {\n query: ctx.query,\n answer: null,\n sources: [],\n confidence: ctx.top_similarity,\n escalated: true,\n escalation_message: `A question could not be answered with sufficient confidence and requires human review.\\n\\n*Question:* ${ctx.query}\\n*Best similarity score:* ${ctx.top_similarity.toFixed(3)}\\n\\nPlease respond to the user directly.`,\n response_type: 'escalation'\n }\n}];"
      },
